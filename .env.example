# ============================
# 人生K线 - 环境变量配置
# ============================
# 复制此文件为 .env 并填写实际值

# --- DeepSeek API（命理分析）---
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# --- 视觉识别 API（图片OCR识别）---
# 阿里云 DashScope qwen-vl-ocr
VITE_VISION_API_KEY=sk-your-dashscope-key-here
VITE_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_VISION_MODEL=qwen-vl-ocr
