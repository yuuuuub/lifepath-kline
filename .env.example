# ============================
# 人生K线 - 环境变量配置
# ============================
# 复制此文件为 .env 并填写实际值

# --- DeepSeek API（命理分析）---
VITE_DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# --- 视觉识别 API（图片OCR中转）---
# 可用 OpenAI GPT-4o、Gemini 等支持图片的模型
VITE_VISION_API_KEY=sk-your-vision-api-key-here
VITE_VISION_BASE_URL=https://api.openai.com/v1
VITE_VISION_MODEL=gpt-4o
